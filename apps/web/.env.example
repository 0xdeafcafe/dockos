# docking web — local dev environment
#
# Copy to `.env.local` and adjust. Mock mode is ON by default (even with no env file), so the app
# runs standalone against the phase-0 fixtures. Flip these two to talk to the real @dockos/server.

# Route every rpc() call to the built-in mock data instead of HTTP.
#   unset / true  → mock fixtures (default; app runs with no backend)
#   false         → hit the real backend over HTTP
VITE_USE_MOCK=false

# Base URL the RPC client prefixes onto /rpc/<method> (and the OIDC /auth/login redirect).
#   ""                       → same origin (how the SPA is served in production)
#   http://localhost:8080    → the server's default dev port (PORT env, defaults to 8080)
VITE_API_BASE=http://localhost:8080
